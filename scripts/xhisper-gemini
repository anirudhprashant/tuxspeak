#!/bin/bash

# xhisper-gemini - Record speech → transcribe → AI polish → type at cursor
# Fork of xhisper with Gemini text polishing

[ -f "$HOME/.env" ] && source "$HOME/.env"

if [ -z "$GEMINI_API_KEY" ]; then
  echo "Error: GEMINI_API_KEY not set. Add it to ~/.env:" >&2
  echo '  GEMINI_API_KEY=your_gemini_api_key_here' >&2
  exit 1
fi
API_KEY="$GEMINI_API_KEY"

RECORDING="/tmp/xhisper-gemini.wav"
LOGFILE="/tmp/xhisper-gemini.log"
HISTORY_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/xhisper/history.txt"
PROCESS_PATTERN="pw-record.*$RECORDING"

# Ensure history directory and file exist
mkdir -p "$(dirname "$HISTORY_FILE")"
touch "$HISTORY_FILE"

# Default configuration
long_recording_threshold=1000
transcription_prompt=""
silence_threshold=-50
silence_percentage=95
non_ascii_initial_delay=0.1
non_ascii_default_delay=0.025

CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/xhisper/xhisperrc"
if [ -f "$CONFIG_FILE" ]; then
  while IFS=: read -r key value || [ -n "$key" ]; do
    [[ "$key" =~ ^[[:space:]]*# ]] && continue
    [[ -z "$key" ]] && continue
    key=$(echo "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    value=$(echo "$value" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//;s/^"//;s/"$//')
    case "$key" in
      long-recording-threshold) long_recording_threshold="$value" ;;
      transcription-prompt) transcription_prompt="$value" ;;
      silence-threshold) silence_threshold="$value" ;;
      silence-percentage) silence_percentage="$value" ;;
      non-ascii-initial-delay) non_ascii_initial_delay="$value" ;;
      non-ascii-default-delay) non_ascii_default_delay="$value" ;;
    esac
  done < "$CONFIG_FILE"
fi

# Auto-start daemon if not running
if ! pgrep -x xhispertoold > /dev/null; then
    echo "DEBUG: Starting xhispertoold daemon" >> "$LOGFILE"
    xhispertoold 2>> /tmp/xhispertoold.log &
    sleep 1  # Give daemon time to start

    # Verify daemon started successfully
    if ! pgrep -x xhispertoold > /dev/null; then
        echo "DEBUG: Failed to start xhispertoold daemon" >> "$LOGFILE"
        echo "Error: Failed to start xhispertoold daemon" >&2
        echo "Check /tmp/xhispertoold.log for details" >&2
        exit 1
    fi
    echo "DEBUG: xhispertoold started successfully" >> "$LOGFILE"
fi

# Ensure xhispertool is installed
if ! command -v xhispertool &> /dev/null; then
  echo "Error: xhispertool not found. Run 'sudo make install' in xhisper directory." >&2
  exit 1
fi

# Detect clipboard tool (test if it actually works, not just if it exists)
if command -v xclip &> /dev/null; then
  CLIP_COPY="xclip -selection clipboard"
  CLIP_PASTE="xclip -o -selection clipboard"
elif command -v wl-copy &> /dev/null && echo "test" | wl-copy 2>/dev/null; then
  CLIP_COPY="wl-copy"
  CLIP_PASTE="wl-paste"
else
  echo "Error: No clipboard tool found. Install xclip or wl-clipboard." >&2
  exit 1
fi

paste() {
  local text="$1"
  echo "DEBUG: Pasting text: [$text]" >> "$LOGFILE"
  for ((i=0; i<${#text}; i++)); do
    local char="${text:$i:1}"
    local ascii=$(printf '%d' "'$char")
    if [[ $ascii -ge 32 && $ascii -le 126 ]]; then
      xhispertool type "$char"
    else
      echo -n "$char" | $CLIP_COPY 2>/dev/null
      xhispertool paste
      [ "$i" -eq 0 ] && sleep "$non_ascii_initial_delay" || sleep "$non_ascii_default_delay"
    fi
  done
}

delete_n_chars() {
  local n="$1"
  for ((i=0; i<n; i++)); do
    xhispertool backspace
  done
}

get_duration() {
  ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$recording" 2>/dev/null || echo "0"
}

is_silent() {
  local recording="$1"
  local vol_stats=$(ffmpeg -i "$recording" -af "volumedetect" -f null /dev/null 2>&1 | grep -E "mean_volume|max_volume")
  local max_vol=$(echo "$vol_stats" | grep "max_volume" | awk '{print $5}')
  if [ -n "$max_vol" ]; then
    local is_quiet=$(echo "$max_vol < $silence_threshold" | bc -l)
    [ "$is_quiet" -eq 1 ] && return 0
  fi
  return 1
}

save_to_history() {
  local text="$1"
  local raw_transcription="$2"
  local timestamp=$(date '+%Y-%m-%d %H:%M:%S')

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" >> "$HISTORY_FILE"
  echo "$timestamp" >> "$HISTORY_FILE"
  echo "" >> "$HISTORY_FILE"
  echo "Polished:" >> "$HISTORY_FILE"
  echo "$text" >> "$HISTORY_FILE"
  echo "" >> "$HISTORY_FILE"
  echo "Raw transcription:" >> "$HISTORY_FILE"
  echo "$raw_transcription" >> "$HISTORY_FILE"
  echo "" >> "$HISTORY_FILE"
}

transcribe() {
  local recording="$1"
  local is_long_recording=$(echo "$(get_duration "$recording") > $long_recording_threshold" | bc -l)
  local model=$([[ $is_long_recording -eq 1 ]] && echo "whisper-large-v3" || echo "whisper-large-v3-turbo")

  local transcription=$(curl -s -X POST "https://api.groq.com/openai/v1/audio/transcriptions" \
    -H "Authorization: Bearer $GROQ_API_KEY" \
    -H "Content-Type: multipart/form-data" \
    -F "file=@$recording" \
    -F "model=$model" \
    -F "prompt=$transcription_prompt" \
    | jq -r '.text' | sed 's/^ //')

  echo "$transcription"
}

polish_with_gemini() {
  local text="$1"

  local response=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=$API_KEY" \
    -H "Content-Type: application/json" \
    -d "{
      \"contents\": [{
        \"parts\": [{
          \"text\": \"Polish this text for clarity and natural flow. Fix grammar, restructure sentences if needed, and make it sound like a well-written message. Keep the meaning intact. Return ONLY the polished text, no explanations or intro:\\n\\n$text\"
        }]
      }]
    }")

  echo "DEBUG: Gemini API response: $response" >> "$LOGFILE"

  # Try to extract polished text, fallback to alternative paths
  local polished=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text // .candidates[0].content.parts[0].string // empty' | sed 's/^```\|```$//' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')

  # If still empty, try a different model
  if [ -z "$polished" ] || [ "$polished" = "null" ] || [ "$polished" = "empty" ]; then
    echo "DEBUG: Primary model failed, trying gemini-1.5-flash" >> "$LOGFILE"
    response=$(curl -s -X POST "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=$API_KEY" \
      -H "Content-Type: application/json" \
      -d "{
        \"contents\": [{
          \"parts\": [{
            \"text\": \"Polish this text for clarity. Fix grammar. Return ONLY the polished text:\\n\\n$text\"
          }]
        }]
      }")
    echo "DEBUG: Gemini 1.5 Flash response: $response" >> "$LOGFILE"
    polished=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text // empty' | sed 's/^```\|```$//' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
  fi

  echo "$polished"
}

# Main

echo "DEBUG: xhisper-gemini started at $(date)" >> "$LOGFILE"

# Add longer delay to prevent double-triggering from keybinding
sleep 0.3

# Check if recording is running
RECORDING_PID=$(pgrep -f "$PROCESS_PATTERN" | head -1)
if [ -n "$RECORDING_PID" ]; then
  # Stop recording
  echo "DEBUG: Stopping recording (PID: $RECORDING_PID)" >> "$LOGFILE"
  pkill -f "$PROCESS_PATTERN"
  sleep 0.5  # Wait for recording to fully stop
  delete_n_chars 14 # "(recording...)"

  # Check for silence
  if is_silent "$RECORDING"; then
    paste "(no sound detected)"
    sleep 0.3
    delete_n_chars 19
    rm -f "$RECORDING"
    exit 0
  fi

  paste "(transcribing...)"
  TRANSCRIPTION=$(transcribe "$RECORDING")
  echo "DEBUG: Raw transcription: [$TRANSCRIPTION]" >> "$LOGFILE"
  sleep 0.3  # Wait longer for typing to complete
  delete_n_chars 17 # "(transcribing...)"

  if [ -z "$TRANSCRIPTION" ] || [ "$TRANSCRIPTION" = "null" ]; then
    paste "(no transcription)"
    sleep 0.3
    delete_n_chars 17
    rm -f "$RECORDING"
    exit 0
  fi

  paste "(polishing...)"
  POLISHED=$(polish_with_gemini "$TRANSCRIPTION")
  echo "DEBUG: Polished response: [$POLISHED]" >> "$LOGFILE"
  sleep 0.3  # Wait longer for typing to complete
  delete_n_chars 15 # Delete one extra character in case of double-trigger space

  # Clean up leading artifacts - simpler approach
  POLISHED=$(echo "$POLISHED" | sed -e 's/^[([{]*//' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
  echo "DEBUG: After cleanup: [$POLISHED]" >> "$LOGFILE"

  if [ -n "$POLISHED" ] && [ "$POLISHED" != "null" ]; then
    paste "$POLISHED"
    save_to_history "$POLISHED" "$TRANSCRIPTION"
  else
    # Fallback to raw transcription if polishing fails
    # Clean up raw transcription too
    TRANSCRIPTION=$(echo "$TRANSCRIPTION" | sed -e 's/^[([{]*//' -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    paste "$TRANSCRIPTION"
    save_to_history "$TRANSCRIPTION" "(polishing failed)"
  fi

  rm -f "$RECORDING"
else
  # Start recording
  echo "DEBUG: Starting recording" >> "$LOGFILE"
  sleep 0.2
  paste "(recording...)"
  pw-record --channels=1 --rate=16000 "$RECORDING"
fi

echo "DEBUG: xhisper-gemini ended at $(date)" >> "$LOGFILE"
